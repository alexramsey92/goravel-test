APP_NAME=GoravelTest
APP_ENV=local
APP_KEY=
APP_DEBUG=true

LOG_CHANNEL=stack
LOG_LEVEL=debug

SESSION_DRIVER=file
SESSION_LIFETIME=120

APP_URL=http://localhost:3000
APP_HOST=127.0.0.1
APP_PORT=3000

# Generate with: go run . artisan jwt:secret
JWT_SECRET=
JWT_TTL=60

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite — no server needed, file is created automatically on first migrate.
# To switch to PostgreSQL or MySQL see README.md.
DB_DATABASE=database/goravel.db

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=hello@goravel-test.local
MAIL_FROM_NAME=GoravelTest
