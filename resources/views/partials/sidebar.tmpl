{{ define "partials/sidebar.tmpl" }}
<div class="flex h-screen w-64 flex-col bg-gray-900 fixed inset-y-0 left-0 z-50">
  <!-- Logo -->
  <div class="flex h-16 items-center gap-3 px-6 border-b border-gray-700">
    <div class="h-8 w-8 rounded-lg bg-indigo-600 flex items-center justify-center">
      <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
      </svg>
    </div>
    <span class="text-white font-semibold text-lg">Goravel Test</span>
  </div>

  <!-- Nav -->
  <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
    <a href="/dashboard" class="sidebar-link {{ if eq .activePage "dashboard" }}active{{ end }}">
      <svg class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 018.25 20.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/>
      </svg>
      Dashboard
    </a>

    <p class="px-4 pt-4 pb-1 text-xs font-semibold text-gray-500 uppercase tracking-wider">CRM</p>

    <a href="/clients" class="sidebar-link {{ if eq .activePage "clients" }}active{{ end }}">
      <svg class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
      </svg>
      Clients
    </a>

    <p class="px-4 pt-4 pb-1 text-xs font-semibold text-gray-500 uppercase tracking-wider">Content</p>

    <a href="/pages" class="sidebar-link {{ if eq .activePage "pages" }}active{{ end }}">
      <svg class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
      </svg>
      Pages
    </a>
  </nav>

  <!-- User footer -->
  <div class="border-t border-gray-700 px-3 py-4">
    <div class="flex items-center gap-3 px-2 mb-2">
      <div class="h-8 w-8 rounded-full bg-indigo-500 flex items-center justify-center text-white text-sm font-medium flex-shrink-0">
        {{ if .user }}{{ slice .user.Name 0 1 }}{{ else }}?{{ end }}
      </div>
      <div class="min-w-0">
        <p class="text-sm font-medium text-white truncate">{{ if .user }}{{ .user.Name }}{{ end }}</p>
        <p class="text-xs text-gray-400 truncate">{{ if .user }}{{ .user.Role }}{{ end }}</p>
      </div>
    </div>
    <form method="POST" action="/logout">
      <button type="submit" class="sidebar-link w-full">
        <svg class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75"/>
        </svg>
        Sign out
      </button>
    </form>
  </div>
</div>
{{ end }}
