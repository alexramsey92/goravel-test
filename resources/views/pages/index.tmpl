{{define "pages/index.tmpl"}}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pages — GoravelTest</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-gray-50 flex">

  <!-- Sidebar -->
  <aside class="w-56 bg-white border-r border-gray-200 flex flex-col">
    <div class="px-6 py-5 border-b border-gray-100">
      <span class="text-lg font-bold text-gray-900">GoravelTest</span>
    </div>
    <nav class="flex-1 p-3 space-y-1">
      <a href="/dashboard"
        class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {{if eq .activePage "dashboard"}}bg-indigo-50 text-indigo-700{{else}}text-gray-600 hover:bg-gray-100{{end}}">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        Dashboard
      </a>
      <a href="/clients"
        class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {{if eq .activePage "clients"}}bg-indigo-50 text-indigo-700{{else}}text-gray-600 hover:bg-gray-100{{end}}">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Clients
      </a>
      <a href="/pages"
        class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {{if eq .activePage "pages"}}bg-indigo-50 text-indigo-700{{else}}text-gray-600 hover:bg-gray-100{{end}}">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        Pages
      </a>
    </nav>
    <div class="p-4 border-t border-gray-100">
      <div class="text-xs text-gray-500 mb-2 truncate">{{.user.Name}}</div>
      <form method="POST" action="/logout">
        <button type="submit" class="text-xs text-red-500 hover:text-red-700">Sign out</button>
      </form>
    </div>
  </aside>

  <!-- Main -->
  <main class="flex-1 p-8">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Pages</h1>
        <p class="text-gray-500 text-sm mt-1">Manage your CMS pages</p>
      </div>
      <a href="/pages/create"
        class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg transition-colors">
        New Page
      </a>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
      {{if .pages}}
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Title</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Slug</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {{range .pages}}
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 text-sm font-medium text-gray-900">{{.Title}}</td>
            <td class="px-6 py-4 text-sm text-gray-500 font-mono">/{{.Slug}}</td>
            <td class="px-6 py-4">
              {{if .Published}}
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">Published</span>
              {{else}}
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-500">Draft</span>
              {{end}}
            </td>
            <td class="px-6 py-4 text-right">
              <form method="POST" action="/pages/{{.ID}}/delete" class="inline"
                onsubmit="return confirm('Delete this page?')">
                <button type="submit" class="text-sm text-red-500 hover:underline">Delete</button>
              </form>
            </td>
          </tr>
          {{end}}
        </tbody>
      </table>
      {{else}}
      <div class="text-center py-16 text-gray-400">
        <p class="text-lg">No pages yet</p>
        <a href="/pages/create" class="mt-3 inline-block text-sm text-indigo-600 hover:underline">Create your first page</a>
      </div>
      {{end}}
    </div>
  </main>

</body>
</html>
{{end}}
